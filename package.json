{
  "name": "tiny-pony-clipper",
  "version": "1.1.1",
  "repository": "https://github.com/JasminDreasond/Tiny-Pony-Clipper.git",
  "bugs": {
    "url": "https://github.com/JasminDreasond/Tiny-Pony-Clipper/issues"
  },
  "homepage": "https://github.com/JasminDreasond/Tiny-Pony-Clipper#readme",
  "description": "A background clipping tool optimized for Wayland and X11.",
  "author": {
    "name": "Yasmin Seidel (JasminDreasond)",
    "email": "tiny@puddy.club",
    "url": "https://www.npmjs.com/~jasmindreasond"
  },
  "main": "src/main.js",
  "type": "module",
  "license": "AGPL-3.0-only",
  "keywords": [
    "electron",
    "wayland",
    "ffmpeg",
    "screen-recorder",
    "remote-play",
    "webrtc",
    "gamepad-streaming",
    "local-multiplayer-online",
    "virtual-gamepad",
    "uinput",
    "input-streaming",
    "streaming",
    "clipping-tool",
    "linux",
    "pulseaudio",
    "pipewire",
    "nvenc"
  ],
  "scripts": {
    "start": "yarn build:npx && electron .",
    "fix:prettier": "prettier --write ./src/*",
    "build:npx": "npx node-gyp configure build",
    "build:linux": "yarn build:npx && electron-builder --linux -p never",
    "build:release": "yarn build:npx && electron-builder --linux -p always"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1"
  },
  "build": {
    "appId": "com.jasmindreasond.tinyponyclipper",
    "productName": "Tiny Pony Clipper",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "host": "github.com",
      "owner": "JasminDreasond",
      "repo": "Tiny-Pony-Clipper",
      "releaseType": "release"
    },
    "releaseInfo": {
      "releaseNotesFile": "release-notes.md"
    },
    "files": [
      "node_modules/node-addon-api/**/*",
      "node_modules/ws/**/*",
      "node_modules/.yarn-integrity",
      "node_modules/.package-lock.json",
      "build/**/*",
      "src/**/*",
      "package.json",
      "package-lock.json"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ],
      "icon": "src/icons/tray-icon.png",
      "category": "Video",
      "executableName": "tiny-pony-clipper",
      "synopsis": "Record and save gameplay clips instantly."
    },
    "deb": {
      "depends": [
        "ffmpeg",
        "pulseaudio-utils",
        "libnotify-bin"
      ]
    },
    "appImage": {
      "license": "LICENSE"
    }
  },
  "dependencies": {
    "node-addon-api": "^8.6.0",
    "ws": "^8.20.0"
  }
}
